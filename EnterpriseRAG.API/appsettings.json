{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MiniLM": {
    "ModelPath": "AIModels/model.onnx",
    "VocabularyPath": "AIModels/vocab.txt",
    "EmbeddingDimension": 384
  },

  "Qdrant": {
    "Host": "localhost",
    "Port": 6334,
    "CollectionName": "documents"
  },

  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "phi4"
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Chunking": {
    "ChunkSize": 500,
    "ChunkOverlap": 100
  }
}
